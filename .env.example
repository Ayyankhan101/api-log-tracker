# Environment variables for LLM providers
# Uncomment the one you want to use

# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...

# LLM_PROVIDER=grok
# XAI_API_KEY=...

# LLM_PROVIDER=groq
# GROQ_API_KEY=...

# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=...

# LLM_PROVIDER=qwen
# DASHSCOPE_API_KEY=...

# LLM_PROVIDER=baichuan
# BAICHUAN_API_KEY=...

# LLM_PROVIDER=yi
# YI_API_KEY=...

# LLM_PROVIDER=stepfun
# STEPFUN_API_KEY=...

# LLM_PROVIDER=glm
# ZHIPU_API_KEY=id.secret

# LLM_PROVIDER=ernie
# BAIDU_API_KEY=...
# BAIDU_API_SECRET=...

# Optional: override default model
# LLM_MODEL=gpt-4o

# CSV log path
API_LOGGER_CSV=logs/api_logs.csv
