		"chalk": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^4.0.0",
		"prettier": "^2.8.7",
		"tsx": "^4.23.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.10",
		"xo": "^0.53.1"
	},
	"xo": {
		"extends": "xo-react",
